---
import Social from "./Social.astro";
---

<footer class="max-w-[1200px] m-auto px-4 py-8">
  <div class="border-t-2 border-black mb-8"></div>

  <div class="container mx-auto">
    <div class="flex flex-col items-center text-center gap-4">
      <div class="brand-section flex flex-col items-center max-w-2xl">
        <h2 class="rozha text-5xl mb-4 text-black">La Font</h2>

        <p class="description text-balance leading-relaxed mb-4">
          El Portal La Font recull diversos articles amb inclinació literària i
          d'opinió; s'hi escriu amb llibertat absoluta. <span
            class="italic font-semibold">Fundada el 2025.</span
          >
        </p>

        <div class="flex justify-center w-full">
          <Social />
        </div>
      </div>
    </div>
  </div>

  <div
    class="mt-7 text-center text-xs uppercase tracking-widest border-t border-black/10 pt-4"
  >
    Sant Hilari Sacalm — {new Date().getFullYear()}
  </div>
</footer>
