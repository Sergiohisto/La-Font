---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  url: string;
  title: string;
  description: string;
  image: ImageMetadata;
}

const { url, title, description, image } = Astro.props;
---

<a
  href={url}
  class="block shadow-lg transition-shadow duration-300 transform hover:-translate-y-1 h-full"
>
  <article class="flex flex-col h-full">
    <h2 class="text-black text-2xl text-center sm:text-3xl font-bold mb-4 font-display">
      {title}
    </h2>
    <div class="flex-shrink-0 rounded-lg overflow-hidden">
      <Image
        src={image}
        alt={`Imagen para ${title}`}
        class="w-full h-[180px] lg:h-[300px] object-cover"
      />
    </div>

    <div class="p-4 flex flex-col justify-between flex-grow">
      <p
        class="text-gray-900 text-[18px] sm:text-[20px] lg:text-[22px] text-justify leading-8 line-clamp-5 mt-2"
      >
        {description}
      </p>
    </div>
  </article>
</a>
